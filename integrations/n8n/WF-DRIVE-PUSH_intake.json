      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\n\n// If state already exists, do nothing\nif (staticData.driveWatch?.channelId && staticData.driveWatch?.pageToken) {\n  return [{ json: staticData.driveWatch }];\n}\n\n// Read headers from webhook trigger\nconst h = $json.headers ?? {};\n\nconst channelId = h['x-goog-channel-id'] ?? null;\nconst resourceId = h['x-goog-resource-id'] ?? null;\nconst channelToken = h['x-goog-channel-token'] ?? null;\nconst resourceUri = h['x-goog-resource-uri'] ?? null;\n\n// Extract pageToken from resourceUri (?pageToken=...)\nlet pageToken = null;\nif (resourceUri) {\n  const m = resourceUri.match(/[?&]pageToken=([^&]+)/);\n  if (m) pageToken = decodeURIComponent(m[1]);\n}\n\n// Parse expiration header to ms\nconst expHeader = h['x-goog-channel-expiration'] ?? null;\nconst expirationMs = expHeader ? Date.parse(expHeader) : null;\n\n// Intake folder from Config node\nconst intakeFolderId = \"1tBji5XdYzKyXrTfhenNkmYPdmlQ2M6Jq\";\n\nif (!channelId || !resourceId || !pageToken || !intakeFolderId) {\n  return [{\n    json: {\n      ok: false,\n      reason: 'bootstrap_failed',\n      channelId,\n      resourceId,\n      pageToken,\n      intakeFolderId\n    }\n  }];\n}\n\n// Persist\nstaticData.driveWatch = {\n  folderId: intakeFolderId,\n  pageToken,\n  channelId,\n  resourceId,\n  channelToken,\n  expirationMs,\n  resourceUri,\n  updatedAtMs: Date.now(),\n  bootstrap: true\n};\n\nreturn [{ json: staticData.driveWatch }];\n"
