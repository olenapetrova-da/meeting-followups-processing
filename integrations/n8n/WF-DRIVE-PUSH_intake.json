        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst intakeFolderId = staticData.driveWatch?.folderId;\n\nconst changes = $json.changes ?? [];\nconst newStart = $json.newStartPageToken ?? null;\n\n// Advance token ASAP (so you don\u2019t reprocess the same changes)\nif (newStart) {\n  staticData.driveWatch = staticData.driveWatch ?? {};\n  staticData.driveWatch.pageToken = newStart;\n  staticData.driveWatch.updatedAtMs = Date.now();\n}\n\n// Filter to files in intake folder\nconst out = [];\nfor (const ch of changes) {\n  if (!ch || ch.removed) continue;\n  const f = ch.file;\n  if (!f || f.trashed) continue;\n\n  const parents = f.parents ?? [];\n  if (!parents.includes(intakeFolderId)) continue;\n\n  // Optional: restrict to audio/video\n  const mt = (f.mimeType ?? '').toLowerCase();\n  const okMedia = mt.startsWith('audio/') || mt.startsWith('video/');\n  if (!okMedia) continue;\n\n  out.push({\n    drive_file_id: ch.fileId,\n    drive_file_name: f.name,\n    drive_file_url: f.webViewLink,\n    mimeType: f.mimeType,\n  });\n}\n\nreturn out.map(x => ({ json: x }));\n"
